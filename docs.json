{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Agent Skills by ft.ia.br",
  "description": "Documentação das skills do repositório fabricioctelles/skills para agentes de IA.",
  "colors": {
    "primary": "#16A34A",
    "light": "#07C983",
    "dark": "#15803D"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Guias",
        "groups": [
          {
            "group": "Comece aqui",
            "pages": [
              "index",
              "quickstart",
              "development"
            ]
          },
          {
            "group": "Skills",
            "pages": [
              "skills/index",
              "skills/premium-proposal-builder",
              "skills/geo-optimization",
              "skills/substack-expert",
              "skills/pier-cloud",
              "skills/ultimate-design-system-master",
              "skills/front-end-checklist",
              "skills/resume-ats-beater",
              "skills/coolify-operator"
            ]
          }
        ]
      },
      {
        "tab": "Referência",
        "groups": [
          {
            "group": "Formato Agent Skills",
            "pages": [
              "essentials/markdown",
              "essentials/reusable-snippets"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Repositório",
          "href": "https://github.com/fabricioctelles/skills",
          "icon": "book-open-cover"
        },
        {
          "anchor": "Especificação",
          "href": "https://agentskills.io/specification.md",
          "icon": "newspaper"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "href": "https://github.com/fabricioctelles/skills"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Instalar skills",
      "href": "https://skills.sh/docs"
    }
  },
  "contextual": {
    "options": [
     "copy",
     "view",
     "chatgpt",
     "claude",
     "perplexity",
     "mcp",
     "cursor",
     "vscode"
   ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/fabricioctelles",
      "github": "https://github.com/fabricioctelles/skills",
      "linkedin": "https://linkedin.com/company/ft-ia-br"
    }
  }
}
